---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE, getPostLink } from "../../consts";
import { formatYMD } from "../../utils/date-helper";
import { sortBlogPosts } from "../../utils/blog";

const posts = sortBlogPosts(await getCollection("blog"));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section class="archive card" aria-labelledby="archive-title">
        <h1 id="archive-title">Blog</h1>
        <ul>
          {
            posts.map((post) => (
              <li>
                <span class="date">{formatYMD(post.data.pubDate)}</span>
                <a href={getPostLink(post)} class="title">
                  {post.data.title}
                </a>
                <p class="description">{post.data.description}</p>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .archive {
    margin-top: 0.8rem;
    padding: 1.2rem;
  }

  .archive h1 {
    margin-bottom: 1rem;
  }

  .archive ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.9rem;
  }

  .archive li {
    border-bottom: 1px dashed var(--color-border);
    padding-bottom: 0.8rem;
  }

  .archive li:last-child {
    border-bottom: 0;
    padding-bottom: 0;
  }

  .date {
    color: var(--color-muted);
    font-size: 0.82rem;
    display: inline-block;
    margin-bottom: 0.3rem;
  }

  .title {
    display: block;
    color: var(--color-primary-dark);
    font-weight: 600;
    margin-bottom: 0.2rem;
  }

  .description {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.92rem;
  }
</style>
