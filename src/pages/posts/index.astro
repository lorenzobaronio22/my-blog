---
import { getCollection } from "astro:content";
import BaseHead from "../../components/BaseHead.astro";
import Footer from "../../components/Footer.astro";
import Header from "../../components/Header.astro";
import { SITE_DESCRIPTION, SITE_TITLE, getPostLink } from "../../consts";
import { formatYMD } from "../../utils/date-helper";
import { sortPosts } from "../../utils/posts";

const posts = sortPosts(await getCollection("posts"));
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <section class="archive card" aria-labelledby="archive-title">
        <h1 id="archive-title">Posts</h1>
        <ul>
          {
            posts.map((post) => (
              <li>
                <span class="date">{formatYMD(post.data.pubDate)}</span>
                <a href={getPostLink(post)} class="title">
                  {post.data.title}
                </a>
                <p class="description">{post.data.description}</p>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .archive {
    margin-top: 0.8rem;
    padding: 1.2rem;
  }

  .archive h1 {
    margin-bottom: 1rem;
  }

  .archive ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .archive li {
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.7rem 0.75rem;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .archive li:hover,
  .archive li:focus-within {
    border-color: color-mix(
      in srgb,
      var(--color-primary) 60%,
      var(--color-border)
    );
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .date {
    color: var(--color-muted);
    font-size: 0.86rem;
    display: inline-block;
    margin-bottom: 0.2rem;
  }

  .title {
    display: block;
    color: var(--color-primary-dark);
    font-weight: 600;
    font-size: 1.03rem;
    line-height: 1.35;
    margin-bottom: 0.35rem;
  }

  .description {
    margin: 0;
    color: var(--color-muted);
    font-size: 0.95rem;
  }
</style>
