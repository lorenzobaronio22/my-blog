---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import AvatarImage from "../components/AvatarImage.astro";
import { SITE_DESCRIPTION, SITE_TITLE, getPostLink } from "../consts";
import { getAllPosts } from "../utils/posts";
import { getMD } from "../utils/date-helper";

const latestGreatestPosts = (await getAllPosts()).slice(0, 4);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <section class="intro card" aria-labelledby="home-intro-title">
        <AvatarImage />
        <h1 id="home-intro-title">Code &amp; Cables</h1>
        <p>{SITE_DESCRIPTION}</p>
      </section>

      <section
        class="latest-greatest card"
        aria-labelledby="latest-greatest-title"
      >
        <div class="latest-header">
          <h2 id="latest-greatest-title">Latest Posts</h2>
          <a class="all-posts-link" href="/posts/">Browse all posts</a>
        </div>
        <p class="latest-hint">Start here with the newest articles.</p>
        <ul>
          {
            latestGreatestPosts.map((post) => (
              <li>
                <a class="post-link" href={getPostLink(post)}>
                  {post.data.title}
                </a>
                <time
                  class="post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {getMD(post.data.pubDate)}
                </time>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .intro {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: 0.8rem;
    padding: 1.7rem 1.2rem;
    margin-top: 0.8rem;
  }

  .intro h1 {
    margin: 0;
  }

  .intro p {
    margin: 0;
    max-width: 46ch;
    color: var(--color-muted);
  }

  .build-date {
    margin-top: -0.5rem;
    font-size: 0.85rem;
    font-weight: 400;
    color: var(--color-muted);
  }

  .latest-greatest {
    margin-top: 1.2rem;
    padding: 1.4rem;
  }

  .latest-greatest h2 {
    margin-bottom: 0;
  }

  .latest-header {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.8rem;
    margin-bottom: 0.35rem;
  }

  .all-posts-link {
    color: var(--color-primary-dark);
    font-size: 0.88rem;
    white-space: nowrap;
  }

  .latest-hint {
    margin-bottom: 0.9rem;
    color: var(--color-muted);
    font-size: 0.9rem;
  }

  .latest-greatest ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .latest-greatest li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.55rem 0.65rem;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .latest-greatest li:hover,
  .latest-greatest li:focus-within {
    border-color: color-mix(
      in srgb,
      var(--color-primary) 60%,
      var(--color-border)
    );
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .post-link {
    font-weight: 600;
    color: var(--color-primary-dark);
  }

  .post-date {
    font-size: 0.8rem;
    color: var(--color-muted);
  }

  @media (max-width: 720px) {
    .latest-greatest {
      margin-top: 2rem;
    }

    .latest-header {
      flex-wrap: wrap;
      gap: 0.2rem 0.75rem;
    }

    .latest-greatest li {
      gap: 0.5rem;
    }
  }
</style>
