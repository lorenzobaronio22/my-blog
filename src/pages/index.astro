---
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import { getCollection } from "astro:content";
import { BASE_URL, SITE_DESCRIPTION, SITE_TITLE } from "../consts";
import { sortBlogPosts } from "../utils/blog";

const publicationDate = new Date();
const formattedPublicationDate = publicationDate.toLocaleDateString("en-US", {
  year: "numeric",
  month: "long",
  day: "numeric",
});

const posts = await getCollection("blog");
const latestGreatestPosts = sortBlogPosts(posts).slice(0, 2);
---

<!doctype html>
<html lang="en">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>
  <body>
    <Header />
    <main>
      <section aria-labelledby="home-intro-title">
        <h1 id="home-intro-title">Welcome!</h1>
        <p class="build-date">Published on {formattedPublicationDate}</p>
        <p>
          Ciao! I&apos;m an Italian software engineer who juggles code and
          cables, for work and for fun.
        </p>
        <p>
          This is my personal space, where I share
          <b>notes, experiments, and guides</b>
          from my daily work in software development and my ever-evolving home lab.
        </p>
        <p>Feel free to browse, and take whatever&apos;s useful.</p>
      </section>

      <section class="latest-greatest" aria-labelledby="latest-greatest-title">
        <h2 id="latest-greatest-title">Latest &amp; Greatest</h2>
        <ul>
          {
            latestGreatestPosts.map((post) => (
              <li>
                <a class="post-link" href={`${BASE_URL}blog/${post.id}/`}>
                  {post.data.title}
                </a>
                <time
                  class="post-date"
                  datetime={post.data.pubDate.toISOString()}
                >
                  {post.data.pubDate.toLocaleDateString("en-US", {
                    year: "numeric",
                    month: "short",
                    day: "numeric",
                  })}
                </time>
              </li>
            ))
          }
        </ul>
      </section>
    </main>
    <Footer />
  </body>
</html>

<style>
  .build-date {
    margin-top: -0.5rem;
    font-size: 0.85rem;
    font-weight: 400;
    color: rgb(var(--gray));
  }

  .latest-greatest {
    margin-top: 2.5rem;
  }

  .latest-greatest h2 {
    margin-bottom: 1rem;
  }

  .latest-greatest ul {
    margin: 0;
    padding: 0;
    list-style: none;
    display: grid;
    gap: 0.75rem;
  }

  .latest-greatest li {
    display: flex;
    align-items: baseline;
    gap: 0.75rem;
    flex-wrap: wrap;
  }

  .post-link {
    font-weight: 600;
  }

  .post-date {
    font-size: 0.8rem;
    color: rgb(var(--gray));
  }

  @media (max-width: 720px) {
    .latest-greatest {
      margin-top: 2rem;
    }

    .latest-greatest li {
      gap: 0.5rem;
    }
  }
</style>
