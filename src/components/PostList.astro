---
import { getPostLink } from "../consts";
import { formatYMD } from "../utils/date-helper";

interface PostItem {
  id: string;
  data: {
    title: string;
    pubDate: Date;
  };
}

interface Props {
  posts: PostItem[];
}

const { posts } = Astro.props;
---

<ul class="post-list">
  {
    posts.map((post) => (
      <li>
        <span>{formatYMD(post.data.pubDate)}</span>
        <a href={getPostLink(post)}>{post.data.title}</a>
      </li>
    ))
  }
</ul>

<style>
  .post-list {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .post-list li {
    display: grid;
    grid-template-columns: 120px 1fr;
    gap: 0.6rem;
    align-items: baseline;
    border: 1px solid var(--color-border);
    border-radius: 10px;
    padding: 0.6rem 0.7rem;
    transition:
      border-color 0.15s ease,
      background-color 0.15s ease;
  }

  .post-list li:hover,
  .post-list li:focus-within {
    border-color: color-mix(
      in srgb,
      var(--color-primary) 60%,
      var(--color-border)
    );
    background: color-mix(in srgb, var(--color-primary) 8%, transparent);
  }

  .post-list span {
    color: var(--color-muted);
    font-size: 0.86rem;
  }

  .post-list a {
    color: var(--color-primary-dark);
    font-weight: 600;
    line-height: 1.35;
  }

  @media (max-width: 720px) {
    .post-list li {
      grid-template-columns: 1fr;
      gap: 0.2rem;
    }
  }
</style>
