---
import { Image } from "astro:assets";
import type { CollectionEntry } from "astro:content";
import BaseHead from "../components/BaseHead.astro";
import Footer from "../components/Footer.astro";
import FormattedDate from "../components/FormattedDate.astro";
import Header from "../components/Header.astro";
import { getPostLink } from "../consts";
import { getPostTags, hasHeroImage, hasUpdatedDate } from "../utils/post-entry";

type Props = {
  post: CollectionEntry<"posts">;
  relatedPosts?: CollectionEntry<"posts">[];
};

const { post, relatedPosts = [] } = Astro.props;
const { title, description, pubDate, updatedDate, heroImage, tags } = post.data;
const visibleTags = getPostTags(tags);
---

<html lang="en">
  <head>
    <BaseHead
      title={title}
      description={description}
      image={heroImage?.src}
      type="article"
      publishedTime={pubDate.toISOString()}
      modifiedTime={updatedDate?.toISOString()}
      tags={visibleTags}
    />
    <style>
      main {
        width: min(860px, calc(100% - 1.2rem));
        margin: 0 auto;
        padding-top: 1rem;
      }

      article {
        border: 1px solid var(--color-border);
        border-radius: 14px;
        background: var(--color-surface);
        box-shadow: 0 14px 28px -24px var(--color-shadow);
        overflow: hidden;
      }

      .hero-image {
        width: 100%;
      }

      .hero-image img {
        border-radius: 0;
        display: block;
      }

      .prose {
        max-width: 760px;
        margin: 0 auto;
        padding: 1.25rem;
        color: var(--color-primary-dark);
      }

      .title {
        margin-bottom: 1.2rem;
        padding: 0.4rem 0;
      }

      .back-link {
        display: inline-block;
        color: var(--color-primary-dark);
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
      }

      .title h1 {
        margin: 0.4rem 0;
      }

      .date {
        margin-bottom: 0.35rem;
        color: var(--color-muted);
        font-size: 0.9rem;
      }

      .last-updated-on {
        font-style: italic;
        font-size: 0.85rem;
      }

      .tags {
        margin-top: 0.8rem;
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
      }

      .tags a {
        border: 1px solid var(--color-border);
        border-radius: 999px;
        color: var(--color-primary-dark);
        font-size: 0.8rem;
        padding: 0.2rem 0.55rem;
      }

      .prose hr {
        border: 0;
        border-top: 1px solid var(--color-border);
      }

      .post-nav {
        margin-top: 1.8rem;
      }

      .related {
        margin-top: 1rem;
        border: 1px solid var(--color-border);
        border-radius: 10px;
        padding: 0.9rem;
      }

      .related h2 {
        margin: 0 0 0.7rem;
        font-size: 1.05rem;
      }

      .related ul {
        list-style: none;
        margin: 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.55rem;
      }

      .related a {
        color: var(--color-primary-dark);
      }

      .related .related-date {
        display: block;
        color: var(--color-muted);
        font-size: 0.85rem;
      }

      @media (max-width: 720px) {
        .prose {
          padding: 1rem;
        }
      }
    </style>
  </head>

  <body>
    <Header />
    <main id="main-content" tabindex="-1">
      <article>
        <div class="hero-image">
          {
            hasHeroImage(heroImage) && (
              <Image width={1020} height={510} src={heroImage} alt="" />
            )
          }
        </div>
        <div class="prose">
          <div class="title">
            <a class="back-link" href="/posts/">&larr; Back to posts</a>
            <div class="date">
              <FormattedDate date={pubDate} />
              {
                hasUpdatedDate(updatedDate) && (
                  <div class="last-updated-on">
                    Last updated on <FormattedDate date={updatedDate} />
                  </div>
                )
              }
            </div>
            <h1>{title}</h1>
            {
              visibleTags.length > 0 && (
                <div class="tags">
                  {visibleTags.map((tag) => (
                    <a href={`/tags/${tag}/`}>#{tag}</a>
                  ))}
                </div>
              )
            }
            <hr />
          </div>
          <slot />
          <div class="post-nav">
            <a class="back-link" href="/posts/">&larr; Back to posts</a>
          </div>
          {
            relatedPosts.length > 0 && (
              <section class="related" aria-labelledby="related-title">
                <h2 id="related-title">Related by tags</h2>
                <ul>
                  {relatedPosts.map((relatedPost) => (
                    <li>
                      <a href={getPostLink(relatedPost)}>
                        {relatedPost.data.title}
                      </a>
                      <span class="related-date">
                        <FormattedDate date={relatedPost.data.pubDate} />
                      </span>
                    </li>
                  ))}
                </ul>
              </section>
            )
          }
        </div>
      </article>
    </main>
    <Footer />
  </body>
</html>
